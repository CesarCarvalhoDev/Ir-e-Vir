{
  "name": "Laravel PHP 8.3 + MySQL",
  "image": "mcr.microsoft.com/devcontainers/php:0-8.3",

  "features": {
    "ghcr.io/devcontainers/features/composer:1": {},
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/mysql:1": {
      "version": "8.0",
      "database": "ir_e_vir",
      "user": "root",
      "password": "root"
    },
    "ghcr.io/devcontainers/features/php:1": {
      "version": "8.3",
      "extensions": [
        "pdo_mysql",
        "mbstring",
        "xml"
      ]
    }
  },

  "forwardPorts": [8000, 3306],

  "postCreateCommand": "composer install && cp .env.example .env && php artisan key:generate",

  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "xdebug.php-debug",
        "onecentlin.laravel-blade"
      ]
    }
  }
}
