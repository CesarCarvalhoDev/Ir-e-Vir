{
  "name": "Laravel PHP 8.2",
  "image": "mcr.microsoft.com/devcontainers/php:0-8.2",

  "features": {
    "ghcr.io/devcontainers/features/composer:1": {},
    "ghcr.io/devcontainers/features/node:1": {}
  },

  "forwardPorts": [8000, 3306],

  "postCreateCommand": "sudo apt update && sudo apt install -y php-mysql && composer install && cp .env.example .env && php artisan key:generate",

  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "xdebug.php-debug",
        "onecentlin.laravel-blade"
      ]
    }
  }
}
